# --- Airtable ---
AIRTABLE_API_KEY=pat_xxx          # airtable.com/create/tokens (scopes: data.records read+write)
AIRTABLE_BASE_ID=app_xxx          # from your base URL: airtable.com/app_xxx/...

# --- Apify (the scraper) ---
APIFY_TOKEN=apify_api_xxx         # console.apify.com > Settings > API tokens
APIFY_TASK_ID=xxx                 # the Task ID of your saved Instagram scraper task

# --- Claude (the copywriter) ---
ANTHROPIC_API_KEY=sk-ant-xxx      # console.anthropic.com

# --- Gemini (the designer / "nano banana") ---
GEMINI_API_KEY=xxx                # aistudio.google.com > Get API key

# --- Instagram (the poster) ---
IG_ACCESS_TOKEN=xxx               # long-lived token, see README step 5
IG_USER_ID=xxx                    # your Instagram Business account ID, see README step 5

# --- Vercel ---
BLOB_READ_WRITE_TOKEN=xxx         # auto-added when you create a Blob store in Vercel
CRON_SECRET=make-up-a-long-random-string
